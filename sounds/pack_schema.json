{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/session-sounds/pack-schema/v1",
  "title": "Session Sounds Pack Manifest",
  "description": "Describes a sound pack for the Claude session-sounds system.",
  "type": "object",
  "required": ["schema_version", "name"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version. Currently always 1."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Human-readable pack name. Shown in pack listings."
    },
    "display_name": {
      "type": "string",
      "maxLength": 128,
      "description": "Optional display name (if different from name)."
    },
    "author": {
      "type": "string",
      "maxLength": 128,
      "description": "Pack author or maintainer."
    },
    "description": {
      "type": "string",
      "maxLength": 512,
      "description": "Short description of the pack's theme or contents."
    },
    "category": {
      "type": "string",
      "enum": ["game", "movie", "ambient", "system", "music", "meme", "mixed", "other"],
      "description": "Broad category for organization. Not enforced -- informational only."
    },
    "platform": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["windows", "darwin", "linux"]
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Platforms this pack supports. Packs with system paths should list only compatible platforms."
    },
    "mode": {
      "type": "string",
      "enum": ["bundled", "system", "recipe", "platform-native"],
      "description": "How audio files are sourced. 'bundled' = WAV files in pack dir. 'system' = OS-provided paths. 'recipe' = manifest only. 'platform-native' = OS system sounds auto-discovered."
    },
    "sounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "name"],
        "additionalProperties": false,
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1,
            "description": "Filename (relative to pack dir) or absolute path (system/platform-native mode)."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "description": "Display name shown in session title and logs."
          }
        }
      }
    },
    "pool": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "name"],
        "additionalProperties": false,
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "description": "Alternative to 'sounds' for platform-native packs."
    },
    "events": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "name"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Event-type sounds (error, approval, end). Each value is {file, name}."
    }
  },
  "anyOf": [
    { "required": ["sounds"] },
    { "required": ["pool"] }
  ]
}
